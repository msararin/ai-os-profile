# Auth.js / NextAuth local configuration
# Auth.js v5 accepts AUTH_* and keeps NEXTAUTH_* compatibility aliases.
AUTH_SECRET="generate-a-local-secret-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Compatibility aliases only if a future implementation standardizes on legacy names.
# NEXTAUTH_SECRET="generate-a-local-secret-with-openssl-rand-base64-32"
# NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Allowed owner/internal emails, comma-separated
INTERNAL_ALLOWED_EMAILS="msararin@gmail.com"

# Optional telemetry ledger path for internal dashboard data.
# In production, configure a production-readable path/export. Do not use a local Mac path.
# TELEMETRY_LEDGER_DB_PATH="/path/to/production-readable/aios_observability.sqlite"
# DATABASE_PATH="/path/to/production-readable/public-observability.sqlite"

# Local callback URL to add in Google Console when local browser testing is authorized:
# http://localhost:3000/api/auth/callback/google
